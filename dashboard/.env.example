# ─── Required ────────────────────────────────────────────────────
# OpenRouter API key (free tier works). Used for ASCII art generation.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Required (public repo = optional, but recommended) ──────────
# GitHub token with `contents:read` on Deq710sia/wankle-trials.
# Without this, you're limited to 60 raw.githubusercontent.com requests/hour per IP.
# Create at: https://github.com/settings/tokens (fine-grained, read-only)
GITHUB_TOKEN=ghp_...

# ─── Optional (defaults shown) ───────────────────────────────────
GITHUB_REPO=Deq710sia/wankle-trials
GITHUB_BRANCH=main
